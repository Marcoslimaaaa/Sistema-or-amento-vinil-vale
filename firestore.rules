rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Apenas o próprio usuário autenticado acessa seus dados
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Escrita (create/update): autenticado + dono + validações básicas
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().size() < 100;

      // Delete: autenticado + dono (sem validação de resource.data que não existe em deletes)
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Validação extra para orçamentos: campos obrigatórios e tipos
    match /users/{userId}/orcamentos/{orcId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['id'])
        && (!request.resource.data.keys().hasAny(['tot']) ||
            request.resource.data.tot is number ||
            request.resource.data.tot is string);

      // Delete permitido para o próprio dono
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Contatos Google - acessível por qualquer usuário autenticado
    match /google_contacts/{contactId} {
      allow read, write: if request.auth != null;
    }

    // Conversas WhatsApp - acessível por qualquer usuário autenticado
    match /whatsapp_conversations/{phone} {
      allow read: if request.auth != null;
    }

    // Leads WhatsApp - acessível por qualquer usuário autenticado
    match /whatsapp_leads/{phone} {
      allow read: if request.auth != null;
    }

    // Bloqueia tudo mais por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
